---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import TilCard from '../components/TilCard.astro';

const allTils = await getCollection('til', ({ data }) => {
  return data.draft !== true;
});

const sortedTils = allTils.sort((a, b) =>
  b.data.date.valueOf() - a.data.date.valueOf()
);

const lastUpdated = sortedTils[0]?.data.date.toLocaleDateString('es-ES', {
  month: 'short',
  year: 'numeric'
}) ?? '—';
---

<BaseLayout>
  <section class="til-list">
    <header class="site-header">
      <div class="header-eyebrow">
        <span class="dot"></span>
        <span>~/aprendizajes</span>
      </div>
      <h1 class="blog-title">TIL<span class="cursor">_</span></h1>
    </header>

    <div class="divider"></div>

    {sortedTils.length === 0 ? (
      <p class="empty">
        No hay entradas. Crea la primera en <code>src/content/til/</code>
      </p>
    ) : (
      <div class="entries">
        {sortedTils.map((til, i) => (
          <TilCard
            title={til.data.title}
            date={til.data.date}
            slug={til.id}
            tags={til.data.tags}
            index={i}
          />
        ))}
      </div>
    )}
  </section>
</BaseLayout>

<style>
  .site-header {
    padding-bottom: 2rem;
    animation: headerIn 0.5s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  @keyframes headerIn {
    from { opacity: 0; transform: translateY(-10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .header-eyebrow {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 0.875rem;
  }

  .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-text-muted);
    animation: pulse 2.5s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.4; }
  }

  .blog-title {
    font-family: var(--font-display);
    font-size: clamp(3.25rem, 9vw, 5.5rem);
    font-weight: 800;
    letter-spacing: -0.05em;
    line-height: 0.95;
    color: var(--color-text);
    margin-bottom: 1rem;
  }

  .cursor {
    color: var(--color-text);
    animation: blink 1.1s step-end infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }

  .header-meta {
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .sep {
    opacity: 0.4;
  }

  .divider {
    height: 1px;
    background: var(--color-border);
    margin-bottom: 1.25rem;
    animation: fadeIn 0.4s ease 0.25s both;
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  .empty {
    font-family: var(--font-mono);
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    padding: 3rem 0;
  }

  .empty code {
    font-family: var(--font-mono);
    background: var(--color-accent-dim);
    color: var(--color-accent);
    padding: 0.1em 0.4em;
    border-radius: 3px;
    border: 1px solid rgba(56, 189, 248, 0.15);
  }
</style>
