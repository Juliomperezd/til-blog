---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const tils = await getCollection('til');
  return tils.map(til => ({
    params: { slug: til.id },
    props: { til },
  }));
}

const { til } = Astro.props;
const { Content } = await render(til);

const formattedDate = til.data.date.toLocaleDateString('es-ES', {
  weekday: 'long',
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<BaseLayout title={til.data.title}>
  <article class="til-post">
    <header>
      <time datetime={til.data.date.toISOString()}>{formattedDate}</time>
      <h1>{til.data.title}</h1>
      {til.data.tags && til.data.tags.length > 0 && (
        <ul class="tags">
          {til.data.tags.map(tag => (
            <li class="tag">{tag}</li>
          ))}
        </ul>
      )}
    </header>
    <div class="prose">
      <Content />
    </div>
    <footer>
      <a href="/">&larr; Volver al listado</a>
    </footer>
  </article>
</BaseLayout>

<style>
  .til-post header {
    margin-bottom: var(--spacing-xl);
    padding-bottom: var(--spacing-lg);
    border-bottom: 1px solid var(--color-border);
  }

  time {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    text-transform: capitalize;
  }

  h1 {
    font-size: var(--font-size-2xl);
    font-weight: 700;
    margin-top: var(--spacing-sm);
    line-height: 1.3;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
    list-style: none;
    margin-top: var(--spacing-md);
  }

  .tag {
    font-size: var(--font-size-sm);
    background-color: var(--color-tag-bg);
    color: var(--color-tag-text);
    padding: var(--spacing-xs) var(--spacing-sm);
    border-radius: 4px;
  }

  .til-post footer {
    margin-top: var(--spacing-2xl);
    padding-top: var(--spacing-lg);
    border-top: 1px solid var(--color-border);
  }
</style>
