---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <p>&copy; {year} TIL</p>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    padding: var(--spacing-lg) 0;
    margin-top: auto;
  }

  .footer .container {
    text-align: center;
  }

  .footer p {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
  }
</style>
