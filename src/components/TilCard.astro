---
interface Props {
  title: string;
  date: Date;
  slug: string;
  tags?: string[];
  index?: number;
}

const { title, date, slug, index = 0 } = Astro.props;

const formattedDate = date.toLocaleDateString('es-ES', {
  year: 'numeric',
  month: 'short',
  day: 'numeric'
});
---

<a href={`/til/${slug}`} class="til-card" style={`--delay: ${index * 70}ms`}>
  <article>
    <time datetime={date.toISOString()}>{formattedDate}</time>
    <h2>{title}</h2>
  </article>
  <span class="arrow">→</span>
</a>

<style>
  .til-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    padding: 18px 20px;
    margin-bottom: 0.5rem;
    border-radius: var(--radius);
    position: relative;
    overflow: hidden;
    transition:
      border-color 0.2s ease,
      background 0.2s ease,
      box-shadow 0.2s ease;
    animation: cardIn 0.45s cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: var(--delay);
  }

  @keyframes cardIn {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Left-edge glow sweep on hover */
  .til-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(100deg, var(--color-accent-dim) 0%, transparent 55%);
    opacity: 0;
    transition: opacity 0.25s ease;
    pointer-events: none;
  }

  .til-card:hover {
    border-color: var(--color-border-hover);
    background: var(--color-surface-hover);
    box-shadow:
      0 0 0 1px rgba(56, 189, 248, 0.08),
      0 4px 32px rgba(56, 189, 248, 0.07);
  }

  .til-card:hover::before {
    opacity: 1;
  }

  .til-card:hover .arrow {
    opacity: 1;
    transform: translateX(3px);
    color: var(--color-accent);
  }

  .til-card:hover h2 {
    color: #f0f6ff;
  }

  article {
    position: relative;
    z-index: 1;
    flex: 1;
    min-width: 0;
  }

  time {
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    display: block;
    margin-bottom: 0.45rem;
  }

  h2 {
    font-family: var(--font-display);
    font-size: clamp(1.05rem, 2.5vw, 1.4rem);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.025em;
    color: var(--color-text);
    transition: color 0.2s ease;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .arrow {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--color-text-muted);
    opacity: 0;
    flex-shrink: 0;
    position: relative;
    z-index: 1;
    transition:
      opacity 0.2s ease,
      transform 0.2s ease,
      color 0.2s ease;
  }
</style>
